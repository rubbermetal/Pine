//@version=6
indicator("SMA Rate of Change", overlay=false, max_labels_count=500)

// ──────────────────────────────────────────────────────────────────────────────
// Settings
// ──────────────────────────────────────────────────────────────────────────────
string GRP1        = "Fast SMA ROC"
int    i_smaLen1   = input.int(20,  "SMA Length",      minval=1, maxval=500,  group=GRP1)
int    i_rocLen1   = input.int(9,   "ROC Period",      minval=1, maxval=200,  group=GRP1)
int    i_smooth1   = input.int(1,   "Smoothing (SMA)", minval=1, maxval=100,  group=GRP1, tooltip="1 = no smoothing")
color  i_colUp1    = input.color(color.rgb(0, 230, 118),  "Bull Color", group=GRP1)
color  i_colDn1    = input.color(color.rgb(255, 82, 82),  "Bear Color", group=GRP1)

string GRP2        = "Slow SMA ROC"
bool   i_show2     = input.bool(true, "Show Slow",                           group=GRP2)
int    i_smaLen2   = input.int(200, "SMA Length",      minval=1, maxval=1000, group=GRP2)
int    i_rocLen2   = input.int(9,   "ROC Period",      minval=1, maxval=200,  group=GRP2)
int    i_smooth2   = input.int(1,   "Smoothing (SMA)", minval=1, maxval=100,  group=GRP2, tooltip="1 = no smoothing")
color  i_colUp2    = input.color(color.rgb(100, 181, 246), "Bull Color", group=GRP2)
color  i_colDn2    = input.color(color.rgb(255, 167, 38),  "Bear Color", group=GRP2)

string GRP3        = "Display"
string i_scale     = input.string("Dollar", "Scale Mode", options=["Percent", "Dollar"], group=GRP3, tooltip="Percent = raw ROC %. Dollar = ROC scaled by price.")
bool   i_showHist  = input.bool(true,  "Show Histogram (Fast)", group=GRP3)
bool   i_showFills = input.bool(true,  "Show Fills",            group=GRP3)
bool   i_showDash  = input.bool(true,  "Show Dashboard",        group=GRP3)

// ──────────────────────────────────────────────────────────────────────────────
// Calculations
// ──────────────────────────────────────────────────────────────────────────────
f_calc(_smaLen, _rocLen, _smoothLen) =>
    float rocRaw = ta.roc(ta.sma(close, _smaLen), _rocLen)
    float val    = i_scale == "Dollar" ? close * (rocRaw / 100.0) : rocRaw
    float out    = _smoothLen > 1 ? ta.sma(val, _smoothLen) : val
    [out, rocRaw]

[val1, rocPct1] = f_calc(i_smaLen1, i_rocLen1, i_smooth1)
[val2, rocPct2] = f_calc(i_smaLen2, i_rocLen2, i_smooth2)

float slow = i_show2 ? val2 : na

// Momentum direction
bool fast_rising = not na(val1) and val1 > nz(val1[1])
bool slow_rising = not na(slow) and slow > nz(slow[1])

// Cross signals
bool crossUp = ta.crossover(val1, slow)
bool crossDn = ta.crossunder(val1, slow)

// ──────────────────────────────────────────────────────────────────────────────
// Colors
// ──────────────────────────────────────────────────────────────────────────────
color c1 = val1 >= 0 ? i_colUp1 : i_colDn1
color c2 = slow >= 0 ? i_colUp2 : i_colDn2

color c1line = fast_rising ? i_colUp1 : i_colDn1
color c2line = slow_rising ? i_colUp2 : i_colDn2

// ──────────────────────────────────────────────────────────────────────────────
// Plots
// ──────────────────────────────────────────────────────────────────────────────
hline(0, "Zero", color=color.new(color.gray, 60), linestyle=hline.style_dashed)

// Histogram for fast
plot(i_showHist ? val1 : na, "Fast Hist", style=plot.style_histogram, color=color.new(c1, 60), linewidth=2)

// Lines
p1   = plot(val1, "Fast ROC", color=c1line, linewidth=2)
p2   = plot(i_show2 ? slow : na, "Slow ROC", color=c2line, linewidth=2)
pZero = plot(0.0, display=display.none)

// Fills
fill(p1, pZero, color=i_showFills ? color.new(c1, 88) : na)
fill(p1, p2,    color=i_showFills and i_show2 ? color.new(val1 > slow ? i_colUp1 : i_colDn1, 85) : na)

// Cross markers
plotshape(i_show2 and crossUp ? val1 : na, "Cross Up",  shape.triangleup,   location.absolute, i_colUp1, size=size.tiny)
plotshape(i_show2 and crossDn ? val1 : na, "Cross Down", shape.triangledown, location.absolute, i_colDn1, size=size.tiny)

// ──────────────────────────────────────────────────────────────────────────────
// Dashboard Table
// ──────────────────────────────────────────────────────────────────────────────
if barstate.islast and i_showDash
    var table dash = table.new(position.top_right, 3, 7, bgcolor=color.rgb(20, 20, 30, 10), border_color=color.rgb(60, 60, 80), border_width=1, frame_color=color.rgb(60, 60, 80), frame_width=1)

    string scaleLabel = i_scale == "Dollar" ? " $" : " %"

    // Header
    table.cell(dash, 0, 0, "SMA ROC",      text_color=color.rgb(200, 200, 220), text_size=size.small, text_halign=text.align_center)
    table.cell(dash, 1, 0, "Fast",          text_color=i_colUp1,                text_size=size.small, text_halign=text.align_center)
    table.cell(dash, 2, 0, "Slow",          text_color=i_colUp2,                text_size=size.small, text_halign=text.align_center)

    // Row: SMA Length
    table.cell(dash, 0, 1, "SMA",           text_color=color.rgb(160, 160, 180), text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 1, str.tostring(i_smaLen1), text_color=color.rgb(200, 200, 220), text_size=size.small, text_halign=text.align_center)
    table.cell(dash, 2, 1, i_show2 ? str.tostring(i_smaLen2) : "—", text_color=color.rgb(200, 200, 220), text_size=size.small, text_halign=text.align_center)

    // Row: ROC Period
    table.cell(dash, 0, 2, "ROC",           text_color=color.rgb(160, 160, 180), text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 2, str.tostring(i_rocLen1), text_color=color.rgb(200, 200, 220), text_size=size.small, text_halign=text.align_center)
    table.cell(dash, 2, 2, i_show2 ? str.tostring(i_rocLen2) : "—", text_color=color.rgb(200, 200, 220), text_size=size.small, text_halign=text.align_center)

    // Row: Current Value
    table.cell(dash, 0, 3, "Value",          text_color=color.rgb(160, 160, 180), text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 3, str.tostring(val1, "#.##") + scaleLabel, text_color=c1line, text_size=size.small, text_halign=text.align_center)
    table.cell(dash, 2, 3, i_show2 ? str.tostring(slow, "#.##") + scaleLabel : "—", text_color=c2line, text_size=size.small, text_halign=text.align_center)

    // Row: ROC %
    table.cell(dash, 0, 4, "ROC %",         text_color=color.rgb(160, 160, 180), text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 4, str.tostring(rocPct1, "#.##") + " %", text_color=rocPct1 >= 0 ? i_colUp1 : i_colDn1, text_size=size.small, text_halign=text.align_center)
    table.cell(dash, 2, 4, i_show2 ? str.tostring(rocPct2, "#.##") + " %" : "—", text_color=rocPct2 >= 0 ? i_colUp2 : i_colDn2, text_size=size.small, text_halign=text.align_center)

    // Row: Direction
    table.cell(dash, 0, 5, "Momentum",      text_color=color.rgb(160, 160, 180), text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 5, fast_rising ? "▲ Rising" : "▼ Falling", text_color=fast_rising ? i_colUp1 : i_colDn1, text_size=size.small, text_halign=text.align_center)
    table.cell(dash, 2, 5, i_show2 ? (slow_rising ? "▲ Rising" : "▼ Falling") : "—", text_color=slow_rising ? i_colUp2 : i_colDn2, text_size=size.small, text_halign=text.align_center)

    // Row: Bias
    string biasText  = not i_show2 ? (val1 > 0 ? "Bullish" : "Bearish") : val1 > slow and val1 > 0 ? "Strong Bull" : val1 > slow and val1 <= 0 ? "Weak Bull" : val1 <= slow and val1 > 0 ? "Weak Bear" : "Strong Bear"
    color  biasColor = not i_show2 ? (val1 > 0 ? i_colUp1 : i_colDn1) : val1 > slow ? i_colUp1 : i_colDn1
    table.cell(dash, 0, 6, "Bias",          text_color=color.rgb(160, 160, 180), text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 6, biasText,         text_color=biasColor, text_size=size.small, text_halign=text.align_center)
    table.cell(dash, 2, 6, "",               text_size=size.small)
