// Quad Rotation Strategy - 60/10 Stochastic Pane
// Day Trader Rock Star's Quad Rotation: 4 stochastics (9/3, 14/3, 40/4, 60/10)
// This pane features the SLOWEST stochastic (60,10,10)

//@version=6
indicator("Quad Rotation 60 10", shorttitle="QR 60/10")

// ==================== Stochastic Inputs ====================
var stoch_group = "Stochastic Settings"
periodK1 = input.int(9,  title="%K1 Length", minval=1, group=stoch_group)
smoothK1 = input.int(3,  title="%K1 Smoothing", minval=1, group=stoch_group)
periodD1 = input.int(3,  title="%D1 Smoothing", minval=1, group=stoch_group)
k1 = ta.sma(ta.stoch(close, high, low, periodK1), smoothK1)
d1 = ta.sma(k1, periodD1)

periodK2 = input.int(14, title="%K2 Length", minval=1, group=stoch_group)
smoothK2 = input.int(3,  title="%K2 Smoothing", minval=1, group=stoch_group)
periodD2 = input.int(3,  title="%D2 Smoothing", minval=1, group=stoch_group)
k2 = ta.sma(ta.stoch(close, high, low, periodK2), smoothK2)
d2 = ta.sma(k2, periodD2)

periodK3 = input.int(40, title="%K3 Length", minval=1, group=stoch_group)
smoothK3 = input.int(4,  title="%K3 Smoothing", minval=1, group=stoch_group)
periodD3 = input.int(4,  title="%D3 Smoothing", minval=1, group=stoch_group)
k3 = ta.sma(ta.stoch(close, high, low, periodK3), smoothK3)
d3 = ta.sma(k3, periodD3)

k4source = input.source(close, "Stoch 60/10 Source", group=stoch_group)
periodK4 = input.int(60, title="%K4 Length", minval=1, group=stoch_group)
smoothK4 = input.int(10, title="%K4 Smoothing", minval=1, group=stoch_group)
periodD4 = input.int(10, title="%D4 Smoothing", minval=1, group=stoch_group)
k4 = ta.sma(ta.stoch(k4source, high, low, periodK4), smoothK4)
d4 = ta.sma(k4, periodD4)

// ==================== DTRS Strategy Settings ====================
var dtrs_group = "DTRS Strategy Settings"
rot_window = input.int(20, "Rotation Window (bars)", minval=5, maxval=100, tooltip="Max bars for sequential rotation to complete (fast→slow)", group=dtrs_group)

// ==================== RSI Divergence Settings ====================
var rsi_group = "RSI Divergence Settings"
rsi_fast_len = input.int(5,  "Fast RSI Length", minval=1, group=rsi_group)
rsi_slow_len = input.int(14, "Slow RSI Length", minval=1, group=rsi_group)

// ==================== Display Settings ====================
var disp_group = "Display Settings"
bool i_showDarkMode      = input.bool(false, "Use Dark Mode", group=disp_group)
bool i_showSignals       = input.bool(true,  "Show K/D Cross Signals", group=disp_group)
bool i_showRotation      = input.bool(true,  "Show Rotation Status", group=disp_group)
bool i_showSequence      = input.bool(true,  "Show Sequential Rotation", group=disp_group)
bool i_showRSIDivergence = input.bool(true,  "Show RSI Divergence", group=disp_group)
bool i_showHolyGrail     = input.bool(true,  "Show Holy Grail Signals", group=disp_group)
bool i_showCounterTrend  = input.bool(true,  "Show Counter-Trend Warnings", group=disp_group)
bool i_showConvergence   = input.bool(true,  "Show Convergence Band", group=disp_group)

// ==================================================================================
// RSI Divergence (standalone)
// ==================================================================================
rsi_f   = ta.rsi(close, rsi_fast_len)
rsi_s   = ta.rsi(close, rsi_slow_len)
rsi_div = rsi_f - rsi_s

// ==================================================================================
// Zone Constants
// ==================================================================================
upperBand = 80
lowerBand = 20

// ==================================================================================
// DTRS Strategy Logic
// ==================================================================================

// --- Quad Alignment ---
allOversold   = d1 < lowerBand and d2 < lowerBand and d3 < lowerBand and d4 < lowerBand
allOverbought = d1 > upperBand and d2 > upperBand and d3 > upperBand and d4 > upperBand

// --- Individual Rotation (first bar of turn in extreme zone) ---
turningUp1 = d1 < lowerBand and d1 > d1[1] and d1[1] <= d1[2]
turningDn1 = d1 > upperBand and d1 < d1[1] and d1[1] >= d1[2]
turningUp2 = d2 < lowerBand and d2 > d2[1] and d2[1] <= d2[2]
turningDn2 = d2 > upperBand and d2 < d2[1] and d2[1] >= d2[2]
turningUp3 = d3 < lowerBand and d3 > d3[1] and d3[1] <= d3[2]
turningDn3 = d3 > upperBand and d3 < d3[1] and d3[1] >= d3[2]
turningUp4 = d4 < lowerBand and d4 > d4[1] and d4[1] <= d4[2]
turningDn4 = d4 > upperBand and d4 < d4[1] and d4[1] >= d4[2]

// --- Sequential Rotation Detection ---
bs_up1 = ta.barssince(turningUp1)
bs_up2 = ta.barssince(turningUp2)
bs_up3 = ta.barssince(turningUp3)
bs_up4 = ta.barssince(turningUp4)

seq_bull = not na(bs_up1) and not na(bs_up2) and not na(bs_up3) and not na(bs_up4)
     and bs_up1 > bs_up2 and bs_up2 > bs_up3 and bs_up3 > bs_up4
     and bs_up4 < rot_window
seq_bull_trigger = seq_bull and turningUp4

bs_dn1 = ta.barssince(turningDn1)
bs_dn2 = ta.barssince(turningDn2)
bs_dn3 = ta.barssince(turningDn3)
bs_dn4 = ta.barssince(turningDn4)

seq_bear = not na(bs_dn1) and not na(bs_dn2) and not na(bs_dn3) and not na(bs_dn4)
     and bs_dn1 > bs_dn2 and bs_dn2 > bs_dn3 and bs_dn3 > bs_dn4
     and bs_dn4 < rot_window
seq_bear_trigger = seq_bear and turningDn4

// --- Holy Grail: Quad alignment + RSI divergence confirmation ---
holy_grail_bull = allOversold and rsi_div > 0
holy_grail_bear = allOverbought and rsi_div < 0

// --- Counter-Trend Protection ---
ct_bull_danger = d4 < lowerBand and d4 <= d4[1] and d1 > upperBand
ct_bear_danger = d4 > upperBand and d4 >= d4[1] and d1 < lowerBand

// --- Convergence Band ---
convergence = (d1 * 1.0 + d2 * 2.0 + d3 * 3.0 + d4 * 4.0) / 10.0
spread = (math.abs(d1 - convergence) + math.abs(d2 - convergence) + math.abs(d3 - convergence) + math.abs(d4 - convergence)) / 4.0
conv_color = color.from_gradient(spread, 3.0, 20.0, color.new(color.white, 20), color.new(color.gray, 70))

// --- K/D Cross Signals in extreme zones ---
bullCross = ta.crossover(k4, d4) and d4 < lowerBand
bearCross = ta.crossunder(k4, d4) and d4 > upperBand

// ==================================================================================
// Background Color
// ==================================================================================
darkMode_clr  = color.rgb(0, 0, 0, 0)
lightModeDown = color.new(color.rgb(241, 24, 24), 90)
lightModeUp   = color.new(#02a710, 90)

brokerage1_trend_dir_fma = ta.ema(close, 21)
brokerage1_trend_dir_sma = ta.ema(close, 50)
brokerage1_trend_dir     = brokerage1_trend_dir_fma > brokerage1_trend_dir_sma ? "Up" : "Down"

ct_warn = i_showCounterTrend and (ct_bull_danger or ct_bear_danger)
bgcolor(ct_warn ? color.new(color.orange, 85) : i_showDarkMode ? darkMode_clr : brokerage1_trend_dir == "Up" ? lightModeUp : lightModeDown)

// ==================================================================================
// Grid Layout
// ==================================================================================
onehundredLine = 100
ninetyLine     = 90
tenLine        = 10
midBand        = 50
zeroLine       = 0

onehundred = hline(onehundredLine, "100 Line",   color=color.rgb(120, 123, 134, 50), linestyle=hline.style_solid)
ninety     = hline(ninetyLine,     "Ninety Line", color=color.rgb(120, 123, 134, 50), linestyle=hline.style_dashed)
eighty     = hline(upperBand,      "Upper Band",  color=color.rgb(120, 123, 134, 50), linestyle=hline.style_solid)
fifty      = hline(midBand,        "Mid Band",    color=color.rgb(120, 123, 134, 50), linestyle=hline.style_dashed)
twenty     = hline(lowerBand,      "Lower Band",  color=color.rgb(120, 123, 134, 50), linestyle=hline.style_solid)
ten        = hline(tenLine,        "Ten Line",    color=color.rgb(120, 123, 134, 50), linestyle=hline.style_dashed)
zero       = hline(zeroLine,       "Zero Line",   color=color.rgb(120, 123, 134, 50), linestyle=hline.style_solid)

// Zone fills — overbought (80-100) = RED, oversold (0-20) = GREEN
fill(onehundred, eighty, color=color.new(color.red, 92))
fill(twenty, zero, color=color.new(color.green, 92))

// ==================================================================================
// Plots — Featured: D4 (60,10,10 Slowest Stochastic)
// ==================================================================================

// K line for crossover visibility
plot(k4, title="Stoch K4", color=color.new(color.white, 40), linewidth=1)

// D line glow + shadow (blue glow for slowest stoch)
plot(d4, title="Stoch D4 Glow", linewidth=5, color=color.rgb(44, 117, 255, 0))
plot(d4, title="Stoch D4",      linewidth=4, color=color.rgb(50, 50, 50, d4))

// Convergence band
plot(i_showConvergence ? convergence : na, title="Convergence", color=conv_color, linewidth=1, style=plot.style_line)

// RSI divergence subtle histogram at midline
rsi_div_clamped = math.max(-2.0, math.min(2.0, rsi_div / 15.0))
rsi_div_plot    = 50.0 + rsi_div_clamped
rsi_div_color   = rsi_div > 0 ? color.new(color.green, 60) : color.new(color.red, 60)
plot(i_showRSIDivergence ? rsi_div_plot : na, title="RSI Div", style=plot.style_histogram, color=rsi_div_color, linewidth=2, histbase=50)

// Quad alignment circles
plot(allOversold ? zeroLine : na, style=plot.style_circles, color=color.green, linewidth=2, title="All Oversold")
plot(allOverbought ? onehundredLine : na, style=plot.style_circles, color=color.red, linewidth=2, title="All Overbought")

// K/D cross signals in extreme zones
plotshape(i_showSignals and bullCross, style=shape.triangleup,   location=location.bottom, color=color.green, size=size.tiny, title="Bull K/D Cross")
plotshape(i_showSignals and bearCross, style=shape.triangledown, location=location.top,    color=color.red,   size=size.tiny, title="Bear K/D Cross")

// Rotation status — individual turn detection for featured stochastic
plotshape(i_showRotation and turningUp4, style=shape.labelup,   location=location.bottom, color=color.new(color.green, 30), text="TURN", textcolor=color.white, size=size.tiny, title="Turning Up")
plotshape(i_showRotation and turningDn4, style=shape.labeldown, location=location.top,    color=color.new(color.red, 30),   text="TURN", textcolor=color.white, size=size.tiny, title="Turning Down")

// Sequential rotation — fires when all 4 have turned in order (fast→slow)
plotshape(i_showSequence and seq_bull_trigger, style=shape.diamond, location=location.bottom, color=color.new(color.green, 0), text="SEQ", textcolor=color.white, size=size.small, title="Sequential Bull Rotation")
plotshape(i_showSequence and seq_bear_trigger, style=shape.diamond, location=location.top,    color=color.new(color.red, 0),   text="SEQ", textcolor=color.white, size=size.small, title="Sequential Bear Rotation")

// Holy Grail — quad alignment + RSI divergence
plotshape(i_showHolyGrail and holy_grail_bull, style=shape.flag, location=location.bottom, color=color.new(#FFD700, 0), text="HG", textcolor=color.white, size=size.small, title="Holy Grail Bull")
plotshape(i_showHolyGrail and holy_grail_bear, style=shape.flag, location=location.top,    color=color.new(#FFD700, 0), text="HG", textcolor=color.white, size=size.small, title="Holy Grail Bear")

// Counter-trend warning
plotshape(i_showCounterTrend and ct_bull_danger, style=shape.xcross, location=location.top,    color=color.orange, size=size.tiny, title="Counter-Trend Bull Danger")
plotshape(i_showCounterTrend and ct_bear_danger, style=shape.xcross, location=location.bottom, color=color.orange, size=size.tiny, title="Counter-Trend Bear Danger")

// ==================================================================================
// Alert Conditions
// ==================================================================================
alertcondition(allOversold,       "Quad Oversold",                 "All 4 stochastics below 20 — rotation buy zone")
alertcondition(allOverbought,     "Quad Overbought",               "All 4 stochastics above 80 — rotation sell zone")
alertcondition(bullCross,         "Bull K/D Cross (60/10)",        "K4 crossed above D4 in oversold zone")
alertcondition(bearCross,         "Bear K/D Cross (60/10)",        "K4 crossed below D4 in overbought zone")
alertcondition(turningUp4,        "Rotation Turning Up (60/10)",   "Slowest stoch turning up from oversold")
alertcondition(turningDn4,        "Rotation Turning Down (60/10)", "Slowest stoch turning down from overbought")
alertcondition(seq_bull_trigger,  "Sequential Rotation Buy",       "All 4 stochastics turned up in sequence (fast to slow)")
alertcondition(seq_bear_trigger,  "Sequential Rotation Sell",      "All 4 stochastics turned down in sequence (fast to slow)")
alertcondition(holy_grail_bull,   "Holy Grail Buy",                "Quad oversold + RSI bullish divergence")
alertcondition(holy_grail_bear,   "Holy Grail Sell",               "Quad overbought + RSI bearish divergence")
alertcondition(ct_bull_danger,    "Counter-Trend Warning (Long)",  "60/10 stuck below 20 while 9/3 above 80 — exit longs")
alertcondition(ct_bear_danger,    "Counter-Trend Warning (Short)", "60/10 stuck above 80 while 9/3 below 20 — exit shorts")
