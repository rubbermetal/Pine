//@version=6
indicator("SMA Spread OSC", overlay=false, max_labels_count=500)

// ──────────────────────────────────────────────────────────────────────────────
// Settings
// ──────────────────────────────────────────────────────────────────────────────
string GRP1        = "Fast SMA"
int    i_fastLen   = input.int(20,  "Length", minval=1, maxval=500,  group=GRP1)
color  i_colUp1    = input.color(color.rgb(0, 230, 118),  "Bull Color", group=GRP1)
color  i_colDn1    = input.color(color.rgb(255, 82, 82),  "Bear Color", group=GRP1)

string GRP2        = "Slow SMA"
int    i_slowLen   = input.int(200, "Length", minval=1, maxval=1000, group=GRP2)
color  i_colUp2    = input.color(color.rgb(100, 181, 246), "Bull Color", group=GRP2)
color  i_colDn2    = input.color(color.rgb(255, 167, 38),  "Bear Color", group=GRP2)

string GRP3        = "Smoothing"
int    i_smooth    = input.int(1, "Smooth Spread (SMA)", minval=1, maxval=100, group=GRP3, tooltip="1 = no smoothing")

string GRP4        = "Display"
bool   i_showHist  = input.bool(true,  "Show Histogram",        group=GRP4)
bool   i_showFills = input.bool(true,  "Show Fills",            group=GRP4)
bool   i_showBands = input.bool(true,  "Show Avg Distance Bands", group=GRP4)
bool   i_showDash  = input.bool(true,  "Show Dashboard",        group=GRP4)

// ──────────────────────────────────────────────────────────────────────────────
// Core Calculation
// ──────────────────────────────────────────────────────────────────────────────
float fastSMA = ta.sma(close, i_fastLen)
float slowSMA = ta.sma(close, i_slowLen)

// Spread as percentage distance: (fast - slow) / slow * 100
float rawSpread = not na(slowSMA) and slowSMA > 0 ? ((fastSMA - slowSMA) / slowSMA) * 100.0 : 0.0
float spread    = i_smooth > 1 ? ta.sma(rawSpread, i_smooth) : rawSpread

// ──────────────────────────────────────────────────────────────────────────────
// Average Distance over Slow SMA period
// ──────────────────────────────────────────────────────────────────────────────
float avgDistAbove = na
float avgDistBelow = na
float midLine      = na
float pctAbove     = na

if not na(spread)
    float sumAbove   = 0.0
    int   countAbove = 0
    float sumBelow   = 0.0
    int   countBelow = 0

    for i = 0 to i_slowLen - 1
        float s = nz(spread[i])
        if s > 0
            sumAbove   += s
            countAbove += 1
        else if s < 0
            sumBelow   += math.abs(s)
            countBelow += 1

    avgDistAbove := countAbove > 0 ? sumAbove / countAbove : 0.0
    avgDistBelow := countBelow > 0 ? sumBelow / countBelow : 0.0
    pctAbove     := (countAbove / i_slowLen) * 100.0

    // Midline = center between +avgAbove and -avgBelow
    midLine := (avgDistAbove - avgDistBelow) / 2.0

// ──────────────────────────────────────────────────────────────────────────────
// Momentum & Crosses
// ──────────────────────────────────────────────────────────────────────────────
bool rising  = not na(spread) and spread > nz(spread[1])
bool isAbove = spread > nz(midLine)

bool crossAboveMid = ta.crossover(spread, midLine)
bool crossBelowMid = ta.crossunder(spread, midLine)

// ──────────────────────────────────────────────────────────────────────────────
// Colors
// ──────────────────────────────────────────────────────────────────────────────
color cSpread = spread >= nz(midLine) ? i_colUp1 : i_colDn1
color cLine   = rising ? i_colUp1 : i_colDn1
color histCol = spread >= nz(midLine) ? i_colUp1 : i_colDn1

// ──────────────────────────────────────────────────────────────────────────────
// Plots
// ──────────────────────────────────────────────────────────────────────────────
priceAbove = avgDistAbove > 0 ? (slowSMA * (avgDistAbove / 100)) + slowSMA : na
priceBelow =  avgDistBelow > 0 ? slowSMA - (slowSMA * (avgDistBelow / 100)) : na
plot(priceAbove, force_overlay = true, color = color.rgb(255,0,0), offset = i_fastLen)
plot(priceBelow, force_overlay = true, color = color.rgb(2, 252, 85), offset = i_fastLen)
// Midline (the "zero" — centered between avg distances)
pMid = plot(midLine, "Mid Line", color=color.rgb(180, 180, 200, 40), linewidth=1, style=plot.style_line)

// Avg distance bands
plot(i_showBands ? avgDistAbove : na,  "Avg Above Band", color=color.new(i_colUp1, 65), linewidth=1, style=plot.style_stepline)
plot(i_showBands ? -avgDistBelow : na, "Avg Below Band", color=color.new(i_colDn1, 65), linewidth=1, style=plot.style_stepline)

// Histogram
plot(i_showHist ? spread : na, "Histogram", style=plot.style_histogram, color=color.new(histCol, 60), linewidth=2)

// Spread line
pSpread = plot(spread, "Spread", color=cLine, linewidth=2)

// Zero reference (actual 0%)
hline(0, "Zero", color.new(color.gray, 75), hline.style_dotted)

// Fills
fill(pSpread, pMid, color=i_showFills ? color.new(cSpread, 85) : na)

// Cross markers on midline
plotshape(crossAboveMid ? spread : na, "Cross Above Mid", shape.triangleup,   location.absolute, i_colUp1, size=size.tiny)
plotshape(crossBelowMid ? spread : na, "Cross Below Mid",  shape.triangledown, location.absolute, i_colDn1, size=size.tiny)


// ──────────────────────────────────────────────────────────────────────────────
// Dashboard
// ──────────────────────────────────────────────────────────────────────────────
if barstate.islast and i_showDash
    var table dash = table.new(position.top_right, 3, 11, bgcolor=color.rgb(20, 20, 30, 10), border_color=color.rgb(60, 60, 80), border_width=1, frame_color=color.rgb(60, 60, 80), frame_width=1)

    // Header
    table.cell(dash, 0, 0, "SMA Spread",    text_color=color.rgb(200, 200, 220), text_size=size.small, text_halign=text.align_center)
    table.cell(dash, 1, 0, "Fast",           text_color=i_colUp1,                text_size=size.small, text_halign=text.align_center)
    table.cell(dash, 2, 0, "Slow",           text_color=i_colUp2,                text_size=size.small, text_halign=text.align_center)

    // SMA Length
    table.cell(dash, 0, 1, "SMA Len",       text_color=color.rgb(160, 160, 180), text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 1, str.tostring(i_fastLen), text_color=color.rgb(200, 200, 220), text_size=size.small, text_halign=text.align_center)
    table.cell(dash, 2, 1, str.tostring(i_slowLen), text_color=color.rgb(200, 200, 220), text_size=size.small, text_halign=text.align_center)

    // SMA Value
    table.cell(dash, 0, 2, "SMA Value",     text_color=color.rgb(160, 160, 180), text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 2, str.tostring(fastSMA, "#.##"), text_color=color.rgb(200, 200, 220), text_size=size.small, text_halign=text.align_center)
    table.cell(dash, 2, 2, str.tostring(slowSMA, "#.##"), text_color=color.rgb(200, 200, 220), text_size=size.small, text_halign=text.align_center)

    // Price vs SMAs
    color priceVsFast = close > fastSMA ? i_colUp1 : i_colDn1
    color priceVsSlow = close > slowSMA ? i_colUp2 : i_colDn2
    table.cell(dash, 0, 3, "Price vs SMA",  text_color=color.rgb(160, 160, 180), text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 3, close > fastSMA ? "▲ Above" : "▼ Below", text_color=priceVsFast, text_size=size.small, text_halign=text.align_center)
    table.cell(dash, 2, 3, close > slowSMA ? "▲ Above" : "▼ Below", text_color=priceVsSlow, text_size=size.small, text_halign=text.align_center)

    // Spread
    table.cell(dash, 0, 4, "Spread",        text_color=color.rgb(160, 160, 180), text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 4, str.tostring(spread, "#.####") + " %", text_color=cLine, text_size=size.small, text_halign=text.align_center)
    table.cell(dash, 2, 4, "",               text_size=size.small)

    // Momentum
    table.cell(dash, 0, 5, "Momentum",      text_color=color.rgb(160, 160, 180), text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 5, rising ? "▲ Rising" : "▼ Falling", text_color=rising ? i_colUp1 : i_colDn1, text_size=size.small, text_halign=text.align_center)
    table.cell(dash, 2, 5, "",               text_size=size.small)

    // Bias
    string biasText = spread > avgDistAbove ? "Extended Bull" : spread > midLine and spread > 0 ? "Bullish" : spread > midLine and spread <= 0 ? "Weak Bull" : spread > -avgDistBelow ? "Bearish" : "Extended Bear"
    color  biasColor = spread > nz(midLine) ? i_colUp1 : i_colDn1
    table.cell(dash, 0, 6, "Bias",          text_color=color.rgb(160, 160, 180), text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 6, biasText,         text_color=biasColor, text_size=size.small, text_halign=text.align_center)
    table.cell(dash, 2, 6, "",               text_size=size.small)

    // --- Spread Stats ---
    table.cell(dash, 0, 7, "Spread Stats",  text_color=color.rgb(200, 200, 220), text_size=size.small, text_halign=text.align_center)
    table.cell(dash, 1, 7, "(" + str.tostring(i_slowLen) + " bars)", text_color=color.rgb(120, 120, 140), text_size=size.small, text_halign=text.align_center)
    table.cell(dash, 2, 7, "",               text_size=size.small)

    // Avg dist above
    table.cell(dash, 0, 8, "Avg Above",     text_color=color.rgb(160, 160, 180), text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 8, str.tostring(avgDistAbove, "#.####") + " %", text_color=i_colUp1, text_size=size.small, text_halign=text.align_center)
    table.cell(dash, 2, 8, spread > 0 ? str.tostring(spread, "#.####") + " % now" : "—", text_color=spread > 0 ? i_colUp1 : color.rgb(120, 120, 140), text_size=size.small, text_halign=text.align_center)

    // Avg dist below
    table.cell(dash, 0, 9, "Avg Below",     text_color=color.rgb(160, 160, 180), text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 9, str.tostring(avgDistBelow, "#.####") + " %", text_color=i_colDn1, text_size=size.small, text_halign=text.align_center)
    table.cell(dash, 2, 9, spread <= 0 ? str.tostring(math.abs(spread), "#.####") + " % now" : "—", text_color=spread <= 0 ? i_colDn1 : color.rgb(120, 120, 140), text_size=size.small, text_halign=text.align_center)

    // % time above / midline value
    table.cell(dash, 0, 10, "% Above",      text_color=color.rgb(160, 160, 180), text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 10, str.tostring(pctAbove, "#.#") + " %", text_color=pctAbove >= 50 ? i_colUp1 : i_colDn1, text_size=size.small, text_halign=text.align_center)
    table.cell(dash, 2, 10, "mid: " + str.tostring(midLine, "#.####") + " %", text_color=color.rgb(180, 180, 200), text_size=size.small, text_halign=text.align_center)
