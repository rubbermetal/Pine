//@version=6
indicator("Intraday Trading", shorttitle="Intraday", overlay=true)

// ==================== EMA Settings ====================
var ema_group = "EMA Settings"
ema50_high_length  = input.int(50, "EMA 50 High Length", minval=1, group=ema_group)
ema50_low_length   = input.int(50, "EMA 50 Low Length", minval=1, group=ema_group)
ema15_close_length = input.int(15, "EMA 15 Close Length", minval=1, group=ema_group)

// ==================== MACD Settings ====================
var macd_group = "MACD Settings"
fast_length = input.int(3, "Fast Length", minval=1, group=macd_group)
slow_length = input.int(10, "Slow Length", minval=1, group=macd_group)
macd_smooth = input.int(16, "Signal Smoothing", minval=1, group=macd_group)

// ==================== Display Settings ====================
var disp_group = "Display Settings"
i_showSignals = input.bool(true, "Show Entry Signals", group=disp_group)
i_showEMAs    = input.bool(true, "Show EMAs", group=disp_group)
i_showCloud   = input.bool(true, "Show EMA 50 Cloud", group=disp_group)

// ==================================================================================
// Core Calculations
// ==================================================================================
ema50_high  = ta.ema(high, ema50_high_length)
ema50_low   = ta.ema(low, ema50_low_length)
ema15_close = ta.ema(close, ema15_close_length)
sma_fast    = ta.sma(close, fast_length)
sma_slow    = ta.sma(close, slow_length)
macd_line   = sma_fast - sma_slow
signal_line = ta.sma(macd_line, macd_smooth)

// Entry conditions — MACD cross + price above/below EMA structure
long_condition  = ta.crossover(macd_line, signal_line) and close > ema15_close and close > ema50_low and ema15_close > ema50_low
short_condition = ta.crossunder(macd_line, signal_line) and close < ema15_close and close < ema50_high and ema15_close < ema50_high

// Trend state
bullTrend = close > ema15_close and ema15_close > ema50_low
bearTrend = close < ema15_close and ema15_close < ema50_high

// ==================================================================================
// Plots
// ==================================================================================
pHigh = plot(i_showEMAs ? ema50_high : na, "EMA 50 High", color=color.new(color.red, 30), linewidth=1)
pLow  = plot(i_showEMAs ? ema50_low : na, "EMA 50 Low", color=color.new(color.green, 30), linewidth=1)
plot(i_showEMAs ? ema15_close : na, "EMA 15 Close", color=color.new(color.blue, 0), linewidth=2)

// EMA 50 cloud fill
cloudColor = i_showCloud ? (bullTrend ? color.new(color.green, 90) : bearTrend ? color.new(color.red, 90) : color.new(color.gray, 95)) : color(na)
fill(pHigh, pLow, color=cloudColor, title="EMA 50 Cloud")

// Entry signals
plotshape(i_showSignals and long_condition,  style=shape.triangleup,   location=location.belowbar, color=color.green, text="Long",  textcolor=color.green, size=size.small, title="Long Entry")
plotshape(i_showSignals and short_condition, style=shape.triangledown, location=location.abovebar, color=color.red,   text="Short", textcolor=color.red,   size=size.small, title="Short Entry")

// Trend background
bgcolor(bullTrend ? color.new(color.green, 95) : bearTrend ? color.new(color.red, 95) : na, title="Trend BG")

// ==================================================================================
// Alert Conditions
// ==================================================================================
alertcondition(long_condition,  "Intraday Long Signal",  "MACD crossover with bullish EMA structure")
alertcondition(short_condition, "Intraday Short Signal", "MACD crossunder with bearish EMA structure")
alertcondition(bullTrend and not bullTrend[1], "Bullish Trend Start", "Price moved above EMA 15 and EMA 50 structure")
alertcondition(bearTrend and not bearTrend[1], "Bearish Trend Start", "Price moved below EMA 15 and EMA 50 structure")
