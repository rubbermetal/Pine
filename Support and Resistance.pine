//@version=6
indicator("Support and Resistance", shorttitle="S/R", overlay=true)

// ==================== S/R Settings ====================
var sr_group = "S/R Settings"
dailyLen  = input.int(200, "Daily S/R Lookback", minval=10, group=sr_group)
hourlyLen = input.int(200, "Hourly Support Lookback", minval=10, group=sr_group)
bandPct   = input.float(0.5, "Band Width (%)", minval=0.1, step=0.1, group=sr_group)

// ==================== EMA Settings ====================
var ema_group = "Zero-Lag EMA"
emaLength   = input.int(10, "EMA Length", minval=1, group=ema_group)
i_showEMA   = input.bool(true, "Show Zero-Lag EMA", group=ema_group)

// ==================== Display Settings ====================
var disp_group = "Display Settings"
i_showBands    = input.bool(true, "Show S/R Bands", group=disp_group)
i_showSignals  = input.bool(true, "Show Break/Test Signals", group=disp_group)
resColor       = input.color(color.red, "Resistance Color", group=disp_group)
supColor       = input.color(color.green, "Support Color", group=disp_group)

// ==================================================================================
// S/R Level Calculations
// ==================================================================================

// Daily highest high and lowest low as major S/R
last_high       = request.security(syminfo.tickerid, "D", ta.highest(high, dailyLen), lookahead=barmerge.lookahead_off)
last_low        = request.security(syminfo.tickerid, "D", ta.lowest(low, dailyLen), lookahead=barmerge.lookahead_off)
current_support = request.security(syminfo.tickerid, "60", ta.lowest(low, hourlyLen), lookahead=barmerge.lookahead_off)

// Band levels (percentage above/below S/R)
mult = bandPct / 100
resistance_high = last_high * (1 + mult)
resistance_low  = last_high * (1 - mult)
support_high    = last_low * (1 + mult)
support_low     = last_low * (1 - mult)

// Dynamic support tracking — resets when broken
support_broken = ta.crossover(low, current_support)
var float support_level = na
support_level := support_broken ? current_support : nz(support_level[1], current_support)

// ==================================================================================
// Zero-Lag EMA
// ==================================================================================
emaStd    = ta.ema(close, emaLength)
emaZeroLag = 2 * emaStd - ta.ema(emaStd, emaLength)

// ==================================================================================
// Signal Detection
// ==================================================================================

// Resistance test/break
nearResistance = high >= resistance_low and high <= resistance_high
resBreakout    = close > resistance_high and close[1] <= resistance_high[1]

// Support test/break
nearSupport    = low <= support_high and low >= support_low
supBreakdown   = close < support_low and close[1] >= support_low[1]

// Retest signals — price returns to broken level
resRetest = close[1] > resistance_high[1] and low <= resistance_high and close > resistance_high
supRetest = close[1] < support_low[1] and high >= support_low and close < support_low

// ==================================================================================
// Plots
// ==================================================================================

// Resistance band
resActive = last_high >= high
pResH = plot(resActive and i_showBands ? resistance_high : na, "Resistance High", color=color.new(resColor, 30), linewidth=1, style=plot.style_linebr)
pResL = plot(resActive and i_showBands ? resistance_low : na, "Resistance Low", color=color.new(resColor, 30), linewidth=1, style=plot.style_linebr)
fill(pResH, pResL, color=resActive and i_showBands ? color.new(resColor, 85) : color(na), title="Resistance Band")

// Support band
supActive = last_low <= low
pSupH = plot(supActive and i_showBands ? support_high : na, "Support High", color=color.new(supColor, 30), linewidth=1, style=plot.style_linebr)
pSupL = plot(supActive and i_showBands ? support_low : na, "Support Low", color=color.new(supColor, 30), linewidth=1, style=plot.style_linebr)
fill(pSupH, pSupL, color=supActive and i_showBands ? color.new(supColor, 85) : color(na), title="Support Band")

// Key hourly support
plot(support_level <= low ? current_support : na, "Key Support", color=color.new(supColor, 20), linewidth=2, style=plot.style_linebr)

// Zero-lag EMA
emaColor = emaZeroLag > emaZeroLag[1] ? color.green : color.red
plot(i_showEMA ? emaZeroLag : na, "Zero-Lag EMA", color=emaColor, linewidth=2)

// Break/test signals
plotshape(i_showSignals and resBreakout, style=shape.triangleup,   location=location.abovebar, color=color.lime,   text="Break", textcolor=color.lime,   size=size.tiny, title="Resistance Breakout")
plotshape(i_showSignals and supBreakdown,style=shape.triangledown, location=location.belowbar, color=color.orange, text="Break", textcolor=color.orange, size=size.tiny, title="Support Breakdown")
plotshape(i_showSignals and resRetest,   style=shape.circle, location=location.abovebar, color=color.new(color.lime, 30),   size=size.tiny, title="Resistance Retest")
plotshape(i_showSignals and supRetest,   style=shape.circle, location=location.belowbar, color=color.new(color.orange, 30), size=size.tiny, title="Support Retest")

// ==================================================================================
// Alert Conditions
// ==================================================================================
alertcondition(resBreakout,    "Resistance Breakout",  "Price broke above resistance band")
alertcondition(supBreakdown,   "Support Breakdown",    "Price broke below support band")
alertcondition(resRetest,      "Resistance Retest",    "Price retesting broken resistance from above")
alertcondition(supRetest,      "Support Retest",       "Price retesting broken support from below")
alertcondition(nearResistance, "Near Resistance",      "Price is testing the resistance band")
alertcondition(nearSupport,    "Near Support",         "Price is testing the support band")
