//@version=6
indicator("Reversal RSI Stochastic ATR", shorttitle="Reversal", overlay=true)

// ==================== RSI Settings ====================
var rsi_group = "RSI Settings"
rsi_length     = input.int(14, "RSI Length", minval=1, group=rsi_group)
rsi_overbought = input.int(70, "RSI Overbought", minval=50, maxval=100, group=rsi_group)
rsi_oversold   = input.int(30, "RSI Oversold", minval=0, maxval=50, group=rsi_group)

// ==================== Stochastic Settings ====================
var stoch_group = "Stochastic Settings"
stoch_length     = input.int(14, "Stochastic Length", minval=1, group=stoch_group)
stoch_k          = input.int(3, "%K Smoothing", minval=1, group=stoch_group)
stoch_d          = input.int(3, "%D Smoothing", minval=1, group=stoch_group)
stoch_overbought = input.int(80, "Stoch Overbought", minval=50, maxval=100, group=stoch_group)
stoch_oversold   = input.int(20, "Stoch Oversold", minval=0, maxval=50, group=stoch_group)

// ==================== ATR Settings ====================
var atr_group = "ATR Risk Management"
atr_length     = input.int(14, "ATR Length", minval=1, group=atr_group)
atr_multiplier = input.float(1.5, "ATR Multiplier", minval=0.5, step=0.5, group=atr_group)

// ==================== Display Settings ====================
var disp_group = "Display Settings"
i_showSignals = input.bool(true, "Show Entry Signals", group=disp_group)
i_showSLTP    = input.bool(true, "Show SL/TP Lines", group=disp_group)
i_showInfo    = input.bool(true, "Show Info Table", group=disp_group)

// ==================================================================================
// Core Calculations
// ==================================================================================
rsi = ta.rsi(close, rsi_length)
stoch_k_line = ta.sma(ta.stoch(close, high, low, stoch_length), stoch_k)
stoch_d_line = ta.sma(stoch_k_line, stoch_d)
atr = ta.atr(atr_length)

// Reversal signals — RSI extreme + stochastic K/D cross in extreme zone
long_signal  = rsi < rsi_oversold and stoch_k_line < stoch_oversold and ta.crossover(stoch_k_line, stoch_d_line)
short_signal = rsi > rsi_overbought and stoch_k_line > stoch_overbought and ta.crossunder(stoch_k_line, stoch_d_line)

// ATR-based SL/TP
var float entrySL = na
var float entryTP = na
var float entryPrice = na
var bool  isLong = false

if long_signal
    entryPrice := close
    entrySL := close - atr * atr_multiplier
    entryTP := close + atr * atr_multiplier
    isLong := true
if short_signal
    entryPrice := close
    entrySL := close + atr * atr_multiplier
    entryTP := close - atr * atr_multiplier
    isLong := false

// Check if SL/TP hit (to clear lines)
slHit = (isLong and not na(entrySL) and low <= entrySL) or (not isLong and not na(entrySL) and high >= entrySL)
tpHit = (isLong and not na(entryTP) and high >= entryTP) or (not isLong and not na(entryTP) and low <= entryTP)

if slHit or tpHit
    entrySL := na
    entryTP := na
    entryPrice := na

// ==================================================================================
// Plots
// ==================================================================================

// Entry signals
plotshape(i_showSignals and long_signal,  style=shape.triangleup,   location=location.belowbar, color=color.green, text="Rev Long",  textcolor=color.green, size=size.small, title="Long Reversal")
plotshape(i_showSignals and short_signal, style=shape.triangledown, location=location.abovebar, color=color.red,   text="Rev Short", textcolor=color.red,   size=size.small, title="Short Reversal")

// SL/TP reference lines
plot(i_showSLTP and not na(entrySL) ? entrySL : na, "Stop Loss", color=color.new(color.orange, 30), style=plot.style_linebr, linewidth=1)
plot(i_showSLTP and not na(entryTP) ? entryTP : na, "Take Profit", color=color.new(color.lime, 30), style=plot.style_linebr, linewidth=1)
plot(i_showSLTP and not na(entryPrice) ? entryPrice : na, "Entry", color=color.new(color.gray, 50), style=plot.style_linebr, linewidth=1)

// Signal background
bgcolor(long_signal ? color.new(color.green, 90) : short_signal ? color.new(color.red, 90) : na, title="Signal BG")

// Info table
var tbl = table.new(position.top_right, 2, 4, bgcolor=color.new(color.black, 50), border_width=1, border_color=color.new(color.gray, 50))
if i_showInfo and barstate.islast
    table.cell(tbl, 0, 0, "RSI", text_color=color.gray, text_size=size.tiny)
    table.cell(tbl, 1, 0, str.tostring(rsi, "#.0"), text_color=rsi > rsi_overbought ? color.red : rsi < rsi_oversold ? color.green : color.white, text_size=size.tiny)
    table.cell(tbl, 0, 1, "Stoch K", text_color=color.gray, text_size=size.tiny)
    table.cell(tbl, 1, 1, str.tostring(stoch_k_line, "#.0"), text_color=stoch_k_line > stoch_overbought ? color.red : stoch_k_line < stoch_oversold ? color.green : color.white, text_size=size.tiny)
    table.cell(tbl, 0, 2, "ATR", text_color=color.gray, text_size=size.tiny)
    table.cell(tbl, 1, 2, str.tostring(atr, format.mintick), text_color=color.white, text_size=size.tiny)
    statusTxt = not na(entryPrice) ? (isLong ? "LONG" : "SHORT") : "FLAT"
    statusClr = not na(entryPrice) ? (isLong ? color.green : color.red) : color.gray
    table.cell(tbl, 0, 3, "Status", text_color=color.gray, text_size=size.tiny)
    table.cell(tbl, 1, 3, statusTxt, text_color=statusClr, text_size=size.tiny)

// ==================================================================================
// Alert Conditions
// ==================================================================================
alertcondition(long_signal,  "Bullish Reversal",  "RSI oversold + Stoch K/D bullish cross in oversold zone")
alertcondition(short_signal, "Bearish Reversal",  "RSI overbought + Stoch K/D bearish cross in overbought zone")
alertcondition(slHit,        "Stop Loss Hit",     "Price hit the ATR-based stop loss level")
alertcondition(tpHit,        "Take Profit Hit",   "Price hit the ATR-based take profit level")
