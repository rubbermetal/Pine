//@version=6
indicator("ROC MA Slope", overlay=false, max_labels_count=500)

// ──────────────────────────────────────────────────────────────────────────────
// Settings
// ──────────────────────────────────────────────────────────────────────────────
string GRP0        = "General"
string maType      = input.string("SMA", "MA Type", options=["SMA", "EMA"], group=GRP0)
int    maLen       = input.int(5,  "MA Smoothing Length", minval=1,          group=GRP0)
int    slopeLen    = input.int(5,  "Slope Lookback (LinReg)", minval=2,      group=GRP0)

string GRP1        = "Fast"
int    fastRocLen  = input.int(5,  "ROC Length",  minval=1,                  group=GRP1)
color  i_colUp1    = input.color(color.aqua,    "Bull Color",               group=GRP1)
color  i_colDn1    = input.color(color.fuchsia, "Bear Color",               group=GRP1)

string GRP2        = "Slow"
int    slowRocLen  = input.int(14, "ROC Length",  minval=1,                  group=GRP2)
color  i_colUp2    = input.color(color.lime,   "Bull Color",                group=GRP2)
color  i_colDn2    = input.color(color.orange, "Bear Color",                group=GRP2)

string GRP3        = "Display"
bool   i_showHist  = input.bool(true,  "Show Histogram (Fast MA)", group=GRP3)
bool   i_showFills = input.bool(true,  "Show Fills",               group=GRP3)
bool   i_showSlope = input.bool(true,  "Show Slope Lines",         group=GRP3)
bool   i_showDash  = input.bool(true,  "Show Dashboard",           group=GRP3)

// ──────────────────────────────────────────────────────────────────────────────
// ROC + MA
// ──────────────────────────────────────────────────────────────────────────────
fastRoc = ta.roc(close, fastRocLen)
slowRoc = ta.roc(close, slowRocLen)

fastMA = maType == "EMA" ? ta.ema(fastRoc, maLen) : ta.sma(fastRoc, maLen)
slowMA = maType == "EMA" ? ta.ema(slowRoc, maLen) : ta.sma(slowRoc, maLen)

// ──────────────────────────────────────────────────────────────────────────────
// Slope
// ──────────────────────────────────────────────────────────────────────────────
fastSlope = ta.linreg(fastMA, slopeLen, 0) - ta.linreg(fastMA, slopeLen, 1)
slowSlope = ta.linreg(slowMA, slopeLen, 0) - ta.linreg(slowMA, slopeLen, 1)

// ──────────────────────────────────────────────────────────────────────────────
// Momentum & Crosses
// ──────────────────────────────────────────────────────────────────────────────
bool fast_rising = fastSlope > 0
bool slow_rising = slowSlope > 0

bool crossUp = ta.crossover(fastMA, slowMA)
bool crossDn = ta.crossunder(fastMA, slowMA)

// ──────────────────────────────────────────────────────────────────────────────
// Average Distance: Fast MA vs Slow MA over slowRocLen window (as %)
// ──────────────────────────────────────────────────────────────────────────────
int   avgWindow    = slowRocLen * maLen   // use a meaningful window tied to slow params
float avgDistAbove = na
float avgDistBelow = na
float pctAbove     = na

if not na(fastMA) and not na(slowMA)
    float sumAbove   = 0.0
    int   countAbove = 0
    float sumBelow   = 0.0
    int   countBelow = 0

    for i = 0 to avgWindow - 1
        float f    = nz(fastMA[i])
        float s    = nz(slowMA[i])
        float diff = f - s
        if diff > 0
            sumAbove   += diff          // already in % (ROC output)
            countAbove += 1
        else if diff < 0
            sumBelow   += math.abs(diff) // already in % (ROC output)
            countBelow += 1

    avgDistAbove := countAbove > 0 ? sumAbove / countAbove : 0.0
    avgDistBelow := countBelow > 0 ? sumBelow / countBelow : 0.0
    pctAbove     := (countAbove / avgWindow) * 100.0

// ──────────────────────────────────────────────────────────────────────────────
// Colors
// ──────────────────────────────────────────────────────────────────────────────
slopeColor(slope, bullCol, bearCol) =>
    slope > 0
         ? color.new(bullCol, math.max(0, 80 - math.abs(slope) * 500))
         : color.new(bearCol, math.max(0, 80 - math.abs(slope) * 500))

color c1line = slopeColor(fastSlope, i_colUp1, i_colDn1)
color c2line = slopeColor(slowSlope, i_colUp2, i_colDn2)

color c1solid = fast_rising ? i_colUp1 : i_colDn1
color c2solid = slow_rising ? i_colUp2 : i_colDn2

color histCol = fastMA >= 0 ? i_colUp1 : i_colDn1

// ──────────────────────────────────────────────────────────────────────────────
// Plots
// ──────────────────────────────────────────────────────────────────────────────
hline(0, "Zero", color.gray, hline.style_dotted)

// Histogram
plot(i_showHist ? fastMA : na, "Fast Hist", style=plot.style_histogram, color=color.new(histCol, 65), linewidth=2)

// MA lines
p1    = plot(fastMA, "Fast ROC MA", c1line, 2)
p2    = plot(slowMA, "Slow ROC MA", c2line, 2)
pZero = plot(0.0, display=display.none)

// Slope lines
plot(i_showSlope ? fastSlope : na, "Fast Slope", color.new(i_colUp1, 50), 1)
plot(i_showSlope ? slowSlope : na, "Slow Slope", color.new(i_colUp2, 50), 1)

// Fills
fill(p1, pZero, color=i_showFills ? color.new(histCol, 90) : na)
fill(p1, p2,    color=i_showFills ? color.new(fastMA > slowMA ? i_colUp1 : i_colDn1, 85) : na)

// Cross markers
plotshape(crossUp ? fastMA : na, "Cross Up",   shape.triangleup,   location.absolute, i_colUp1, size=size.tiny)
plotshape(crossDn ? fastMA : na, "Cross Down",  shape.triangledown, location.absolute, i_colDn1, size=size.tiny)

// ──────────────────────────────────────────────────────────────────────────────
// Dashboard
// ──────────────────────────────────────────────────────────────────────────────
if barstate.islast and i_showDash
    var table dash = table.new(position.top_right, 3, 11, bgcolor=color.rgb(20, 20, 30, 10), border_color=color.rgb(60, 60, 80), border_width=1, frame_color=color.rgb(60, 60, 80), frame_width=1)

    // Header
    table.cell(dash, 0, 0, "ROC MA Slope",  text_color=color.rgb(200, 200, 220), text_size=size.small, text_halign=text.align_center)
    table.cell(dash, 1, 0, "Fast",           text_color=i_colUp1,                text_size=size.small, text_halign=text.align_center)
    table.cell(dash, 2, 0, "Slow",           text_color=i_colUp2,                text_size=size.small, text_halign=text.align_center)

    // ROC Length
    table.cell(dash, 0, 1, "ROC Len",       text_color=color.rgb(160, 160, 180), text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 1, str.tostring(fastRocLen), text_color=color.rgb(200, 200, 220), text_size=size.small, text_halign=text.align_center)
    table.cell(dash, 2, 1, str.tostring(slowRocLen), text_color=color.rgb(200, 200, 220), text_size=size.small, text_halign=text.align_center)

    // MA Type + Length
    table.cell(dash, 0, 2, maType + " Len",  text_color=color.rgb(160, 160, 180), text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 2, str.tostring(maLen), text_color=color.rgb(200, 200, 220), text_size=size.small, text_halign=text.align_center)
    table.cell(dash, 2, 2, str.tostring(maLen), text_color=color.rgb(200, 200, 220), text_size=size.small, text_halign=text.align_center)

    // MA Value
    table.cell(dash, 0, 3, "MA Value",      text_color=color.rgb(160, 160, 180), text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 3, str.tostring(fastMA, "#.####"), text_color=c1solid, text_size=size.small, text_halign=text.align_center)
    table.cell(dash, 2, 3, str.tostring(slowMA, "#.####"), text_color=c2solid, text_size=size.small, text_halign=text.align_center)

    // Slope Value
    table.cell(dash, 0, 4, "Slope",         text_color=color.rgb(160, 160, 180), text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 4, str.tostring(fastSlope, "#.####"), text_color=c1solid, text_size=size.small, text_halign=text.align_center)
    table.cell(dash, 2, 4, str.tostring(slowSlope, "#.####"), text_color=c2solid, text_size=size.small, text_halign=text.align_center)

    // Momentum
    table.cell(dash, 0, 5, "Momentum",      text_color=color.rgb(160, 160, 180), text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 5, fast_rising ? "▲ Rising" : "▼ Falling", text_color=fast_rising ? i_colUp1 : i_colDn1, text_size=size.small, text_halign=text.align_center)
    table.cell(dash, 2, 5, slow_rising ? "▲ Rising" : "▼ Falling", text_color=slow_rising ? i_colUp2 : i_colDn2, text_size=size.small, text_halign=text.align_center)

    // Bias
    string biasText  = fastMA > slowMA and fastMA > 0 ? "Strong Bull" : fastMA > slowMA and fastMA <= 0 ? "Weak Bull" : fastMA <= slowMA and fastMA > 0 ? "Weak Bear" : "Strong Bear"
    color  biasColor = fastMA > slowMA ? i_colUp1 : i_colDn1
    table.cell(dash, 0, 6, "Bias",          text_color=color.rgb(160, 160, 180), text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 6, biasText,         text_color=biasColor, text_size=size.small, text_halign=text.align_center)
    table.cell(dash, 2, 6, "",               text_size=size.small)

    // --- Spread Stats ---
    table.cell(dash, 0, 7, "Spread Stats",  text_color=color.rgb(200, 200, 220), text_size=size.small, text_halign=text.align_center)
    table.cell(dash, 1, 7, "(" + str.tostring(avgWindow) + " bars)", text_color=color.rgb(120, 120, 140), text_size=size.small, text_halign=text.align_center)
    table.cell(dash, 2, 7, "",               text_size=size.small)

    // Avg dist above (as %)
    table.cell(dash, 0, 8, "Avg Above",     text_color=color.rgb(160, 160, 180), text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 8, str.tostring(avgDistAbove, "#.####") + " %", text_color=i_colUp1, text_size=size.small, text_halign=text.align_center)
    float curSpread = fastMA - slowMA
    bool  isAbove   = curSpread > 0
    table.cell(dash, 2, 8, isAbove ? str.tostring(curSpread, "#.####") + " % now" : "—", text_color=isAbove ? i_colUp1 : color.rgb(120, 120, 140), text_size=size.small, text_halign=text.align_center)

    // Avg dist below (as %)
    table.cell(dash, 0, 9, "Avg Below",     text_color=color.rgb(160, 160, 180), text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 9, str.tostring(avgDistBelow, "#.####") + " %", text_color=i_colDn1, text_size=size.small, text_halign=text.align_center)
    table.cell(dash, 2, 9, not isAbove ? str.tostring(math.abs(curSpread), "#.####") + " % now" : "—", text_color=not isAbove ? i_colDn1 : color.rgb(120, 120, 140), text_size=size.small, text_halign=text.align_center)

    // % time above
    table.cell(dash, 0, 10, "% Above",      text_color=color.rgb(160, 160, 180), text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 10, str.tostring(pctAbove, "#.#") + " %", text_color=pctAbove >= 50 ? i_colUp1 : i_colDn1, text_size=size.small, text_halign=text.align_center)
    table.cell(dash, 2, 10, str.tostring(100.0 - pctAbove, "#.#") + " % below", text_color=pctAbove < 50 ? i_colUp1 : i_colDn1, text_size=size.small, text_halign=text.align_center)
